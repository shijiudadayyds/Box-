# ================================
# Mihomo / Box 配置项目 .gitignore
# ================================

# 订阅缓存（自动生成）
proxy_provider/

# 规则缓存（自动下载）
rule_provider/

# 日志文件
*.log

# 临时文件
*.tmp
*.bak
*.cache

# 系统文件
.DS_Store
Thumbs.db

# Android / 手机端可能产生
*.nomedia

# 编辑器（可选）
.vscode/
.idea/

# Node（防止误上传）
node_modules/

# 压缩包（避免误传订阅）
*.zip
*.tar
*.gz