mixed-port: 7890
port: 7891
socks-port: 12306
redir-port: 9797
tproxy-port: 9898

mode: Rule
bind-address: '*'
ipv6: true
allow-lan: true
unified-delay: true
tcp-concurrent: true
log-level: error
find-process-mode: always

external-controller: 0.0.0.0:9090
external-ui: ./dashboard
# secret: "CHANGE_ME"

profile:
  store-selected: true
  store-fake-ip: true

sniffer:
  enable: true
  override-destination: false
  sniff:
    HTTP:
      ports: [80, 8080-8880]
      override-destination: true
    TLS:
      ports: [443, 8443]
    QUIC:
      ports: [443, 8443]

tun:
  enable: false
  device: meta
  stack: gvisor
  dns-hijack: [any:53, tcp://any:53]
  udp-timeout: 300
  auto-route: true
  auto-redirect: false
  auto-detect-interface: true
  strict-route: false

dns:
  enable: true
  ipv6: true
  listen: 0.0.0.0:1053
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter:
    - "rule-set:Fake-IP-Filter"

  proxy-server-nameserver:
    - 223.5.5.5
    - 1.1.1.1

  nameserver-policy:
    "rule-set:cn_domain":
      - 223.5.5.5
      - 119.29.29.29

  nameserver:
    - 223.5.5.5
    - 119.29.29.29
    - 1.1.1.1
    - 8.8.8.8

proxies:
  - { name: DNS_Hijack, type: dns }

proxy-groups:
  - name: 🚀 总控
    type: select
    proxies:
      - ⚡ 智能测速
      - 🛡️ 故障转移
      - 🇭🇰 香港节点
      - 🇯🇵 日本节点
      - 🇸🇬 新加坡节点
      - 🇺🇸 美国节点
      - 📚 全部节点
      - DIRECT

  - name: ⚡ 智能测速
    type: url-test
    include-all: true
    exclude-type: "dns"
    url: https://cp.cloudflare.com/generate_204
    interval: 300
    tolerance: 50
    lazy: true

  - name: 🛡️ 故障转移
    type: fallback
    include-all: true
    exclude-type: "dns"
    url: https://cp.cloudflare.com/generate_204
    interval: 300
    lazy: true

  - name: 🇭🇰 香港节点
    type: url-test
    include-all: true
    exclude-type: "dns"
    filter: "(?i)(^|[-_\\s\\[\\(【])((港|香港|hk|HKG|hong\\s?kong|hongkong)(?!.*(家宽|宽带|回国|直连|游戏专线))|HKBN|HKT|WTT)([-_\\s\\]\\)】]|$)"
    url: https://cp.cloudflare.com/generate_204
    interval: 300
    tolerance: 50
    lazy: true

  - name: 🇯🇵 日本节点
    type: url-test
    include-all: true
    exclude-type: "dns"
    filter: "(?i)(^|[-_\\s\\[\\(【])((日|日本|jp|JPN|japan|tokyo|osaka|东京|大阪|埼玉|名古屋|福冈|沖縄|冲绳))(?!.*(回国|直连|游戏专线))([\\s\\]\\)】_-]|$)"
    url: https://cp.cloudflare.com/generate_204
    interval: 300
    tolerance: 50
    lazy: true

  - name: 🇸🇬 新加坡节点
    type: url-test
    include-all: true
    exclude-type: "dns"
    filter: "(?i)(^|[-_\\s\\[\\(【])((新|新加坡|狮城|sg|SGP|singapore|lion\\s?city))(?!.*(回国|直连|游戏专线))([\\s\\]\\)】_-]|$)"
    url: https://cp.cloudflare.com/generate_204
    interval: 300
    tolerance: 50
    lazy: true

  - name: 🇺🇸 美国节点
    type: url-test
    include-all: true
    exclude-type: "dns"
    filter: "(?i)(^|[-_\\s\\[\\(【])((美|美国|us|USA|united\\s?states|america|los\\s?angeles|la|san\\s?jose|sjc|silicon\\s?valley|seattle|new\\s?york|ny|dallas|chicago|phoenix|miami|ashburn|fremont|san\\s?francisco|sf))(?!.*(回国|直连|游戏专线))([\\s\\]\\)】_-]|$)"
    url: https://cp.cloudflare.com/generate_204
    interval: 300
    tolerance: 50
    lazy: true

  - name: 📚 全部节点
    type: select
    include-all: true
    exclude-type: "dns"

  - name: 🤖 OpenAI
    type: select
    proxies:
      - 🇯🇵 日本节点
      - 🇸🇬 新加坡节点
      - 🇺🇸 美国节点
      - 🛡️ 故障转移
      - ⚡ 智能测速
      - 🇭🇰 香港节点
      - 🚀 总控
      - 📚 全部节点
      - DIRECT

  - name: ✈️ Telegram
