# =========================================================
# Mihomo / Box Public Example Config
# Public GitHub Edition
# 4 providers + auto test + fallback + region groups + common service routing
# Safe for public repositories: no real subscription URLs included
# =========================================================

proxy-providers:
  Provider1:
    type: http
    url: "REPLACE_WITH_YOUR_SUBSCRIPTION_URL_1"
    path: ./proxy_provider/proxy1.yaml
    interval: 86400
    health-check:
      enable: true
      url: https://cp.cloudflare.com/generate_204
      interval: 300
      timeout: 1000
      tolerance: 100

  Provider2:
    type: http
    url: "REPLACE_WITH_YOUR_SUBSCRIPTION_URL_2"
    path: ./proxy_provider/proxy2.yaml
    interval: 86400
    health-check:
      enable: true
      url: https://cp.cloudflare.com/generate_204
